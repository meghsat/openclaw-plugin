{
  "env": {
    "NEWS_API_KEY": "${NEWS_API_KEY}",
    "ALPHA_VANTAGE_KEY": "${ALPHA_VANTAGE_KEY}"
  },
  "models": {
    "providers": {
      "lemonade": {
        "baseUrl": "http://localhost:8000/api/v1",
        "apiKey": "lemonade",
        "api": "openai-completions",
        "models": [
          {
            "id": "Qwen3-Coder-30B-A3B-Instruct-GGUF",
            "name": "Qwen3 Coder 30B (tool-calling)",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 32768,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "lemonade/Qwen3-Coder-30B-A3B-Instruct-GGUF"
      },
      "imageGenerationModel": {
        "primary": "lemonade/SD-1.5"
      }
    }
  },
  "plugins": {
    "allow": ["lemonade-image"],
    "load": {
      "paths": [
        "~/.openclaw/plugins/lemonade-image"
      ]
    }
  },
  "tools": {
    "web": {
      "fetch": {
        "enabled": true,
        "maxCharsCap": 20000,
        "readability": false
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "${DISCORD_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "guilds": {
        "1484318936362127435": {
          "slug": "my-server",
          "requireMention": false,
          "channels": {
            "1484320997443375176": {
              "allow": true,
              "systemPrompt": "You are LemonBot, a news and market intelligence assistant running on AMD Ryzen AI hardware. When asked for news, fetch and summarize headlines. When asked for stocks/market data, fetch and summarize top movers. Always format as bullet points with sources. Keep responses concise"
            },
            "1484367759524626482": {
              "allow": true,
              "systemPrompt": "You are LemonArt, an image generation bot running on AMD Ryzen AI hardware. Every message you receive is a prompt to generate an image. Always call the image_generate tool with the user's message as the prompt. Do not describe or explain — just generate the image immediately."
            }
          }
        }
      },
      "streaming": "off"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${GATEWAY_TOKEN}"
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.3.14",
    "lastTouchedAt": "2026-03-19T23:01:13.430Z"
  }
}