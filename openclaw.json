{
  "env": {
    "NEWS_API_KEY": "${NEWS_API_KEY}",
    "ALPHA_VANTAGE_KEY": "${ALPHA_VANTAGE_KEY}",
    "LEMONADE_API_KEY": "lemonade",
    "TAVILY_API_KEY": "${TAVILY_API_KEY}"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "lemonade/Qwen3.5-35B-A3B-GGUF"
      },
      "bootstrapMaxChars": 500,
      "bootstrapTotalMaxChars": 2000,
      "imageGenerationModel": {
        "primary": "lemonade/Flux-2-Klein-4B"
      }
    }
  },
  "models": {
    "providers": {
      "lemonade": {
        "baseUrl": "http://127.0.0.1:8000/api/v1",
        "apiKey": "lemonade",
        "api": "openai-completions",
        "models": [
          {
            "id": "Qwen3.5-35B-A3B-GGUF",
            "name": "Qwen3.5-35B-A3B-GGUF",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 32768,
            "maxTokens": 2048
          }
        ]
      }
    }
  },
  "plugins": {
    "entries": {
      "lemonade": { "enabled": true }
    }
  },
  "tools": {
    "web": {
      "fetch": {
        "enabled": true,
        "maxCharsCap": 4000,
        "readability": false
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "${DISCORD_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "guilds": {
        "1484318936362127435": {
          "slug": "my-server",
          "requireMention": false,
          "channels": {
            "1484320997443375176": {
              "allow": true,
              "preRunScript": "python C:/Users/user/.openclaw/workspace/scripts/news_context.py",
              "systemPrompt": "You are LemonBot, a news assistant. A formatted AI news feed is injected into your context. When anyone asks for news, output the COMPLETE formatted news feed EXACTLY as provided — every article, every URL, verbatim. Do not summarize, shorten, or rewrite. Never output NO_REPLY.",
              "tools": {
                "deny": ["*"]
              }
            },
            "1484367759524626482": {
              "allow": true,
              "directImageGen": true
            }
          }
        }
      },
      "streaming": "off"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${GATEWAY_TOKEN}"
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.3.14",
    "lastTouchedAt": "2026-03-19T23:01:13.430Z"
  }
}
