{
  "env": {
    "NEWS_API_KEY": "${NEWS_API_KEY}",
    "ALPHA_VANTAGE_KEY": "${ALPHA_VANTAGE_KEY}",
    "LEMONADE_API_KEY": "lemonade",
    "TAVILY_API_KEY": "${TAVILY_API_KEY}"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "lemonade/qwen3.5-4b-FLM"
      },
      "bootstrapMaxChars": 500,
      "bootstrapTotalMaxChars": 2000,
      "imageGenerationModel": {
        "primary": "lemonade/Flux-2-Klein-4B"
      }
    }
  },
  "models": {
    "providers": {
      "lemonade": {
        "baseUrl": "http://127.0.0.1:8000/api/v1",
        "apiKey": "lemonade",
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen3.5-4b-FLM",
            "name": "qwen3.5-4b-FLM",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 16384,
            "maxTokens": 2048
          }
        ]
      }
    }
  },
  "plugins": {
    "entries": {
      "lemonade": { "enabled": true }
    }
  },
  "tools": {
    "web": {
      "fetch": {
        "enabled": true,
        "maxCharsCap": 4000,
        "readability": false
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "${DISCORD_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "guilds": {
        "1484318936362127435": {
          "slug": "my-server",
          "requireMention": false,
          "channels": {
            "1484320997443375176": {
              "allow": true,
              "preRunScript": "python C:/Users/user/.openclaw/workspace/scripts/news_context.py",
              "systemPrompt": "You are LemonBot, a news and market intelligence assistant. Current AI news has been automatically fetched and is included above. Summarize as 5-7 bullet points: **bold headline**, one-sentence summary, source name. Keep response under 1800 characters. If no articles available, say so briefly.",
              "tools": {
                "deny": ["*"]
              }
            },
            "1484367759524626482": {
              "allow": true,
              "directImageGen": true
            }
          }
        }
      },
      "streaming": "off"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${GATEWAY_TOKEN}"
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.3.14",
    "lastTouchedAt": "2026-03-19T23:01:13.430Z"
  }
}
