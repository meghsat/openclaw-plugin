{
  "env": {
    "NEWS_API_KEY": "${NEWS_API_KEY}",
    "ALPHA_VANTAGE_KEY": "${ALPHA_VANTAGE_KEY}",
    "LEMONADE_API_KEY": "lemonade",
    "TAVILY_API_KEY": "${TAVILY_API_KEY}"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "lemonade/qwen3.5-4b-FLM"
      },
      "imageGenerationModel": {
        "primary": "lemonade/Flux-2-Klein-4B"
      }
    }
  },
  "models": {
    "providers": {
      "lemonade": {
        "baseUrl": "http://127.0.0.1:8000/api/v1",
        "apiKey": "lemonade",
        "api": "openai-completions",
        "models": [
          {
            "id": "qwen3.5-4b-FLM",
            "name": "qwen3.5-4b-FLM",
            "reasoning": false,
            "input": [
              "text"
            ],
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 32768,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "plugins": {
    "entries": {
      "lemonade": { "enabled": true }
    }
  },
  "tools": {
    "web": {
      "fetch": {
        "enabled": true,
        "maxCharsCap": 4000,
        "readability": false
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "${DISCORD_BOT_TOKEN}",
      "groupPolicy": "allowlist",
      "guilds": {
        "1484318936362127435": {
          "slug": "my-server",
          "requireMention": false,
          "channels": {
            "1484320997443375176": {
              "allow": true,
              "systemPrompt": "You are LemonBot, a news and market intelligence assistant running on AMD Ryzen AI hardware.\n\nWhen the user sends 'fetch', 'news', or any similar request for news headlines: run this command using your bash tool:\n  python C:/Users/user/.openclaw/workspace/scripts/news_fetch.py\n\nOnce you have the output, summarize as 5-7 bullet points. Each bullet: **bold headline**, one-sentence summary, source name. Keep total response under 1800 characters. If no articles are found, say so briefly.\n\nWhen asked for stocks or market data, fetch and summarize top movers. Always format as bullet points with sources. Keep responses concise."
            },
            "1484367759524626482": {
              "allow": true,
              "directImageGen": true
            }
          }
        }
      },
      "streaming": "off"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "${GATEWAY_TOKEN}"
    }
  },
  "meta": {
    "lastTouchedVersion": "2026.3.14",
    "lastTouchedAt": "2026-03-19T23:01:13.430Z"
  }
}
